APP_NAME=AI-Powered Hotel Operations Workflow Orchestrator
APP_ENV=development
AUTHOR_NAME=Aditya Pundhir
DATABASE_URL=
REDIS_URL=
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC=hotel-operations-events
WEAVIATE_HTTP_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051
USE_WEAVIATE=false
USE_TRANSFORMERS=false
USE_LANGGRAPH=true
DISTILBERT_MODEL_PATH=models/distilbert-checkpoint
MINILM_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
CROSS_ENCODER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
LAYOUTLM_MODEL_NAME=microsoft/layoutlmv3-base
LAYOUTLM_MODEL_PATH=models/layoutlmv3-checkpoint
FORECAST_MODEL_PATH=models/occupancy_xgb.joblib
SOP_DIRECTORY=data/sops
DEFAULT_SLA_MINUTES=30
HUMAN_APPROVAL_SEVERITY=critical
